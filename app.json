{
  "expo": {
    "name": "PoupaFlex",
    "slug": "poupaflexapp",
    "version": "1.3.5",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "poupaflexapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lucassferreiras.poupaflexapp"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/splash-icon.png",
        "backgroundImage": "./assets/images/splash-icon.png",
        "monochromeImage": "./assets/images/splash-icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.lucassferreiras.poupaflexapp"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4685dbc1-18c0-4173-a146-6f0b680509ff"
      }
    },
    "owner": "lucassferreiras-organization"
  }
}
